# =============================================================================
# .env.example – Copy and rename to envs/.env.dev / .env.qa / .env.prod
# then fill in the values appropriate for that environment.
# Never commit files with real credentials to source control.
# =============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
APP_NAME=ragflow-api
APP_VERSION=0.1.0

# Controls which envs/.env.{APP_ENV} file is loaded at startup.
# Set this as a shell environment variable BEFORE starting the server –
# the scripts/start_*.sh scripts do this automatically.
# Values: dev | qa | prod
APP_ENV=dev

# Enable verbose logging and SQLAlchemy SQL echo (dev only)
DEBUG=true

# Log verbosity: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=DEBUG

# ---------------------------------------------------------------------------
# Server
# ---------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000

# Number of worker processes (use 1 + reload for dev, 4+ for prod)
WORKERS=1

# Auto-reload on code changes (dev only – set false in qa/prod)
RELOAD=true

# ---------------------------------------------------------------------------
# Database – MySQL (local or cloud)
#
# For cloud databases (AWS RDS, GCP Cloud SQL, Azure DB, PlanetScale):
#   - Set DB_HOST to the cloud endpoint/hostname
#   - Set DB_PORT if non-standard (default 3306)
#   - Increase DB_POOL_SIZE / DB_MAX_OVERFLOW for higher concurrency
#   - Lower DB_POOL_RECYCLE to match the cloud provider's idle timeout
# ---------------------------------------------------------------------------
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=ragflow_dev

# Connection pool settings
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# Recycle connections after N seconds (prevents stale-connection errors on cloud)
DB_POOL_RECYCLE=3600

# ---------------------------------------------------------------------------
# Security
# ---------------------------------------------------------------------------
# Generate a strong key: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-strong-random-secret

# JWT token lifetime in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ---------------------------------------------------------------------------
# CORS – comma-separated list of allowed origins (JSON array format)
# Use ["*"] only in dev; restrict in qa/prod
# ---------------------------------------------------------------------------
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8080"]
