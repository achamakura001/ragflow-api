# ── Development environment ────────────────────────────────────────────────────
APP_NAME=ragflow-api
APP_VERSION=0.1.0
APP_ENV=dev
DEBUG=true
LOG_LEVEL=DEBUG

HOST=0.0.0.0
PORT=8000
WORKERS=1
RELOAD=true

DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=ragflow_dev
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_RECYCLE=3600

SECRET_KEY=dev-secret-key-change-me
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Comma-separated list of allowed CORS origins (no spaces around commas)
ALLOWED_ORIGINS=http://localhost:5174,http://localhost:3000,http://localhost:8080
